# RGBDS object outputs. Rebuild; never hand-edit.
*.o

# Generated graphics outputs from source PNG/palette data.
*.1bpp
*.2bpp
*.lz
*.gbcpal
*.dimensions
*.sgb.tilemap

# Built ROM and patch outputs. Root .gbc files are build products.
*.gbc
*.gb
*.patch

# RGBDS linker outputs. .map/.sym are read-only address truth.
*.map
*.sym

# Hand-exported .map.txt copies. `*.map` above doesn't cover the .txt suffix,
# but these are still build-derived; let them stay scratch.
pokegold.map.txt

# Repo-local toolchain downloads and compiled helper binaries.
*.exe
rgbds-1.0.1/
rgbds-win64.zip
rgbds-win64*.zip
rgbds-*/

# Python cache outputs.
*.pyc
*$py.class

# Emulator save/state files.
*.sgm
*.sav
*.rtc
*.sn*
*.sa*
*.sg1
*.state

# Damage debugger harness run logs (regenerated each invocation).
audit/damage_debugger/*.log
audit/damage_debugger/*.jsonl
audit/damage_debugger/*.tenet

# Boss AI debugger run artifacts + Pokemon Mastery loop run artifacts. Both
# directories hold timestamped regenerable outputs (`python -m tools.boss_ai_debugger
# run-suite ...` and the mastery loop drivers under tools/pokemon_mastery/). The
# tools recreate these on demand; tracking them bloats history with hundreds of
# thousands of lines of generated JSON for no review value.
audit/boss_ai_debugger/runs/
docs/pokemon_mastery/runs/

# Boss AI preference lab server runtime logs.
audit/boss_ai_preference/server.*.log

# Local scratch and release output families. Do not broaden these patterns unless
# the path is documented as scratch/output in docs/agent_navigation/source_output_ownership.md.
.local/
/tmp/
.claude/*
!.claude/settings.json
.claude_handoffs/
.rebalance_chain/
*-backup
dist/*.gb
dist/*.gbc
dist/*.sgb
dist/*.sav
dist/*.rtc
dist/*.state
dist/*.zip
